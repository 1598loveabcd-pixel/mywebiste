<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RareBridge RWE - 罕见病真实世界证据桥梁</title>
    <!-- 引入 Tailwind CSS (无需安装，直接通过CDN加载样式) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 FontAwesome 图标库 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        // 配置 Tailwind 主题色
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#3b82f6', // 家长端主色（蓝）
                        pharma: '#8b5cf6', // 药企端主色（紫）
                    }
                }
            }
        }
    </script>
    <style>
        /* 自定义开关样式 */
        .toggle-checkbox:checked {
            right: 0;
            border-color: #68D391;
        }
        .toggle-checkbox:checked + .toggle-label {
            background-color: #68D391;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans min-h-screen pb-10">

    <!-- 导航栏 -->
    <nav class="bg-white shadow-sm border-b border-gray-100">
        <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <i class="fa-solid fa-bridge-water text-primary text-2xl"></i>
                <span class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-500 to-purple-600">
                    RareBridge RWE
                </span>
            </div>
            <div class="space-x-4">
                <button class="text-gray-500 hover:text-primary transition">关于我们</button>
                <button class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-800 transition">
                    登录 / 注册
                </button>
            </div>
        </div>
    </nav>

    <!-- 核心控制区：角色切换 -->
    <div class="max-w-6xl mx-auto px-4 mt-8 mb-6 text-center">
        <h1 class="text-3xl font-bold mb-2">连接罕见病家庭与创新药企</h1>
        <p class="text-gray-500 mb-8">请选择您的演示角色视角</p>
        
        <div class="inline-flex bg-gray-200 rounded-xl p-1 shadow-inner">
            <button id="btn-parent" onclick="switchView('parent')" class="px-8 py-3 rounded-lg font-bold text-sm transition-all duration-300 bg-white text-primary shadow-sm flex items-center">
                <i class="fa-solid fa-house-chimney-medical mr-2"></i> 面向家长端 (供给方)
            </button>
            <button id="btn-pharma" onclick="switchView('pharma')" class="px-8 py-3 rounded-lg font-bold text-sm text-gray-500 transition-all duration-300 hover:text-pharma flex items-center">
                <i class="fa-solid fa-microscope mr-2"></i> 面向药企端 (需求方)
            </button>
        </div>
    </div>

    <!-- ==================== 家长端视图 ==================== -->
    <div id="view-parent" class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-500">
        
        <!-- 模块1：日常症状记录本 -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition">
            <div class="flex items-center mb-4 text-blue-500">
                <i class="fa-solid fa-book-medical text-xl mr-2"></i>
                <h2 class="text-lg font-bold text-gray-800">症状记录本 (ObsRO)</h2>
            </div>
            <p class="text-xs text-gray-400 mb-4">今天孩子的状态如何？数据将自动转化为医学标准格式。</p>
            <form class="space-y-4" onsubmit="event.preventDefault(); alert('记录成功！已生成时间戳并上链。');">
                <div>
                    <label class="block text-sm text-gray-600 mb-1">主要症状</label>
                    <select class="w-full border border-gray-200 rounded-lg p-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
                        <option>肌肉无力 (Muscle Weakness)</option>
                        <option>呼吸困难 (Dyspnea)</option>
                        <option>吞咽困难 (Dysphagia)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm text-gray-600 mb-1">严重程度 (1-10)</label>
                    <input type="range" min="1" max="10" value="5" class="w-full accent-blue-500">
                </div>
                <button class="w-full bg-blue-50 text-blue-600 border border-blue-200 font-bold py-2 rounded-lg text-sm hover:bg-blue-100 transition">
                    打卡记录
                </button>
            </form>
        </div>

        <!-- 模块2：同情用药匹配雷达 -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition">
            <div class="flex items-center mb-4 text-rose-500">
                <i class="fa-solid fa-satellite-dish text-xl mr-2"></i>
                <h2 class="text-lg font-bold text-gray-800">同情用药匹配雷达</h2>
            </div>
            <p class="text-xs text-gray-400 mb-4">基于基因库为您搜寻全球未上市试验药物。</p>
            
            <div class="space-y-3">
                <!-- 匹配项 1 -->
                <div class="border border-green-100 bg-green-50 rounded-lg p-3 relative">
                    <span class="absolute top-2 right-2 text-xs font-bold text-green-600 bg-green-100 px-2 py-1 rounded">匹配度 98%</span>
                    <h3 class="font-bold text-sm text-gray-800 mb-1">NCT0456XXX 基因疗法</h3>
                    <p class="text-xs text-gray-500 mb-2">状态: 接受 Expanded Access 申请</p>
                    <button onclick="alert('已为您生成致FDA的Form 3926申请草稿！')" class="text-xs bg-green-500 text-white px-3 py-1 rounded hover:bg-green-600 transition">申请协助</button>
                </div>
                <!-- 匹配项 2 -->
                <div class="border border-gray-100 rounded-lg p-3 relative">
                    <span class="absolute top-2 right-2 text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded">匹配度 75%</span>
                    <h3 class="font-bold text-sm text-gray-800 mb-1">SMA-002 小分子靶向药</h3>
                    <p class="text-xs text-gray-500">状态: 临床II期 (未开放同情用药)</p>
                </div>
            </div>
        </div>

        <!-- 模块3：数据授权与隐私管家 -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition">
            <div class="flex items-center mb-4 text-emerald-500">
                <i class="fa-solid fa-shield-halved text-xl mr-2"></i>
                <h2 class="text-lg font-bold text-gray-800">隐私管家金库</h2>
            </div>
            <p class="text-xs text-gray-400 mb-4">您的数据，您做主。随时授权或一键撤回。</p>
            
            <div class="space-y-4">
                <div class="flex justify-between items-center border-b border-gray-50 pb-2">
                    <div class="text-sm font-medium text-gray-700">允许用于药企新药研发<br><span class="text-xs text-gray-400">(将获得平台公益津贴)</span></div>
                    <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
                        <input type="checkbox" checked class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer z-10"/>
                        <label class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
                    </div>
                </div>
                <div class="flex justify-between items-center border-b border-gray-50 pb-2">
                    <div class="text-sm font-medium text-gray-700">允许高校免费科研调用<br><span class="text-xs text-gray-400">(完全脱敏匿名化)</span></div>
                    <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
                        <input type="checkbox" checked class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer z-10"/>
                        <label class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
                    </div>
                </div>
                <button onclick="alert('数据授权已全部撤回，数据流已切断！')" class="w-full mt-2 text-red-500 text-sm font-bold py-2 border border-red-100 rounded-lg hover:bg-red-50 transition">
                    一键紧急撤回所有授权
                </button>
            </div>
        </div>
    </div>

    <!-- ==================== 药企端视图 (默认隐藏) ==================== -->
    <div id="view-pharma" class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-6 hidden transition-all duration-500">
        
        <!-- 模块1：外部对照组生成器 -->
        <div class="bg-white rounded-2xl shadow-sm border border-purple-100 p-6 hover:shadow-md transition">
            <div class="flex items-center mb-4 text-pharma">
                <i class="fa-solid fa-users-viewfinder text-xl mr-2"></i>
                <h2 class="text-lg font-bold text-gray-800">外部对照组生成器 (External Control)</h2>
            </div>
            <p class="text-xs text-gray-400 mb-6">免去单臂试验寻找安慰剂组的烦恼，合规调用真实世界脱敏数据。</p>
            
            <div class="bg-gray-50 p-4 rounded-lg mb-4">
                <h3 class="text-sm font-bold mb-2">配置您的入组标准：</h3>
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <input type="text" placeholder="疾病靶点 (如: SMN1)" class="border border-gray-200 p-2 rounded outline-none focus:border-pharma">
                    <input type="text" placeholder="年龄范围 (如: 2-5岁)" class="border border-gray-200 p-2 rounded outline-none focus:border-pharma">
                </div>
            </div>

            <button onclick="generateCohort()" class="w-full bg-pharma text-white font-bold py-3 rounded-lg text-sm hover:bg-purple-700 transition flex justify-center items-center">
                <i class="fa-solid fa-wand-magic-sparkles mr-2"></i> 一键生成合成对照队列 (Synthetic Cohort)
            </button>

            <!-- 生成结果区 (隐藏) -->
            <div id="cohort-result" class="hidden mt-4 p-4 border border-purple-200 bg-purple-50 rounded-lg">
                <p class="text-sm text-purple-800 font-bold mb-1"><i class="fa-solid fa-check-circle mr-1"></i> 生成成功！</p>
                <p class="text-xs text-purple-600">已通过倾向性评分匹配 (PSM) 找到 <strong>128</strong> 名符合特征的历史对照患者。</p>
                <button class="mt-2 text-xs bg-white border border-purple-300 px-3 py-1 rounded text-purple-700 hover:bg-purple-100">导出 CDISC 格式</button>
            </div>
        </div>

        <!-- 模块2&3：数据标准化与获批风险计算器 -->
        <div class="bg-white rounded-2xl shadow-sm border border-purple-100 p-6 hover:shadow-md transition">
            <div class="flex items-center mb-4 text-orange-500">
                <i class="fa-solid fa-chart-pie text-xl mr-2"></i>
                <h2 class="text-lg font-bold text-gray-800">RWE证据质量与获批风险计算器</h2>
            </div>
            <p class="text-xs text-gray-400 mb-4">基于FDA指导原则，评估当前数据集作为监管证据的可靠性。</p>
            
            <!-- 进度条模拟数据评估 -->
            <div class="space-y-4 mt-6">
                <div>
                    <div class="flex justify-between text-xs mb-1">
                        <span class="font-bold text-gray-700">数据标准化率 (NLP自动映射)</span>
                        <span class="text-green-500 font-bold">94%</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-green-500 h-2 rounded-full" style="width: 94%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs mb-1">
                        <span class="font-bold text-gray-700">随访记录连续性</span>
                        <span class="text-yellow-500 font-bold">76%</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-yellow-500 h-2 rounded-full" style="width: 76%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs mb-1">
                        <span class="font-bold text-gray-700">临床终点指标完整度</span>
                        <span class="text-blue-500 font-bold">88%</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-blue-500 h-2 rounded-full" style="width: 88%"></div>
                    </div>
                </div>
            </div>

            <div class="mt-6 p-3 bg-gray-900 text-white rounded-lg flex items-center justify-between">
                <div>
                    <div class="text-xs text-gray-400">FDA 提交成功率预估</div>
                    <div class="text-2xl font-bold text-green-400">A- 级</div>
                </div>
                <button onclick="alert('详细分析报告（包含缺失值修补建议）已发送至您的邮箱！')" class="text-xs border border-gray-600 px-3 py-2 rounded hover:bg-gray-800 transition">查看风险报告</button>
            </div>
        </div>

    </div>

    <!-- 简单的 JS 逻辑，用于演示交互 -->
    <script>
        function switchView(view) {
            const btnParent = document.getElementById('btn-parent');
            const btnPharma = document.getElementById('btn-pharma');
            const viewParent = document.getElementById('view-parent');
            const viewPharma = document.getElementById('view-pharma');

            if (view === 'parent') {
                // 按钮样式改变
                btnParent.className = 'px-8 py-3 rounded-lg font-bold text-sm transition-all duration-300 bg-white text-primary shadow-sm flex items-center';
                btnPharma.className = 'px-8 py-3 rounded-lg font-bold text-sm text-gray-500 transition-all duration-300 hover:text-pharma flex items-center';
                
                // 视图切换
                viewPharma.classList.add('hidden');
                viewParent.classList.remove('hidden');
            } else {
                // 按钮样式改变
                btnPharma.className = 'px-8 py-3 rounded-lg font-bold text-sm transition-all duration-300 bg-white text-pharma shadow-sm flex items-center';
                btnParent.className = 'px-8 py-3 rounded-lg font-bold text-sm text-gray-500 transition-all duration-300 hover:text-primary flex items-center';
                
                // 视图切换
                viewParent.classList.add('hidden');
                viewPharma.classList.remove('hidden');
            }
        }

        // 模拟生成对照组的加载效果
        function generateCohort() {
            const resultBox = document.getElementById('cohort-result');
            resultBox.classList.remove('hidden');
            resultBox.innerHTML = '<p class="text-sm text-gray-500 animate-pulse"><i class="fa-solid fa-spinner fa-spin"></i> 正在算法匹配脱敏数据库...</p>';
            
            setTimeout(() => {
                resultBox.innerHTML = `
                    <p class="text-sm text-purple-800 font-bold mb-1"><i class="fa-solid fa-check-circle mr-1"></i> 生成成功！</p>
                    <p class="text-xs text-purple-600">基于倾向性评分匹配 (PSM)，成功合成 <strong>128</strong> 名符合特征的历史对照患者 (无PHI数据泄露)。</p>
                    <button class="mt-3 text-xs font-bold bg-white shadow-sm border border-purple-200 px-4 py-2 rounded text-purple-700 hover:bg-purple-50 transition">下载 CDISC 标准数据集</button>
                `;
            }, 1500); // 模拟1.5秒延迟
        }
    </script>
</body>
</html>
